@page "/"
<PageTitle>Home | Artur's Portfolio</PageTitle>

<MudContainer Class="mt-16 mb-16" MaxWidth="MaxWidth.Large">
    <MudPaper Class="pa-6" Elevation="3"> 
        <MudContainer Class="d-flex">
            <MudAvatar Class="mud-elevation-25">
                <MudIcon Icon="fas fa-hand-peace" />
            </MudAvatar>

            <MudText Class="ml-2" Typo="Typo.h4" GutterBottom="true">Hi, I'm Artur and I create stuff for people!</MudText>
        </MudContainer>

        <MudText Typo="Typo.body1">
            Welcome to my online portfolio. This Web app was created to showcase my work for a potential employer. Please take a look at the sections below to learn more about me and what I do.
        </MudText>

        @*https://www.springboard.com/blog/careersmithing/programmer-portfolio/*@

        @*About me*@
        <MudContainer Class="d-flex align-center mt-4">
            <MudAvatar Class="mud-elevation-25">
                <MudIcon Icon="@Icons.Filled.Info"/>
            </MudAvatar>

            <MudText Class="ml-2" Typo="Typo.h5">About me</MudText>
        </MudContainer>

        <MudText Class="mt-2" Typo="Typo.body1">
            My name is Artur and I live in Warsaw. I'm a Warsaw University alumnus in English studies (Master of Arts). I'm a self-taught programmer who has been programming for 3 years now, mainly in C# but I also program in TypeScript/JavaScript.
            I love solving programming problems and automating daily tasks. I would like to finally start my professional career and further develop my proficiency in this field.
        </MudText>

        @*Stuff Used*@
        <MudContainer Class="d-flex align-center mt-4">
            <MudAvatar Class="mud-elevation-25">
                <MudIcon Icon="@Icons.Filled.Build"/>
            </MudAvatar>

            <MudText Class="ml-2" Typo="Typo.h5">Summary of my programming experience</MudText>
        </MudContainer>

        <MudText Class="mt-2" Typo="Typo.body1">
            This section shows quick overview of what I have used:

            <MudList>
                <MudListItem>
                    <strong>Programming languages</strong>: C#, TypeScript/JavaScript
                </MudListItem>

                <MudListItem>
                    <strong>Frameworks used</strong>: .NET Framework, .NET Core, .NET, React
                </MudListItem>

                <MudListItem>
                    <strong>Database</strong>: PostgreSQL, Azure SQL Database
                </MudListItem>

                <MudListItem>
                    <strong>Database mapper</strong>: Entity Framework Core, Dapper
                </MudListItem>

                <MudListItem>
                    <strong>Application hosting</strong>: Heroku, Azure
                </MudListItem>

                <MudListItem>
                    <strong>Source code hosting</strong>: GitHub
                </MudListItem>

                <MudListItem>
                    <strong>Preferred version control</strong>: GitKraken
                </MudListItem>
                
                <MudListItem>
                    <strong>IDE</strong>: Visual Studio with Resharper extension
                </MudListItem>
                
                <MudListItem>
                    <strong>Code editor</strong>: Visual Studio Code
                </MudListItem>
            </MudList>

            For in-depth look, please take a look at <strong>Projects</strong> section below.
        </MudText>

        @*Projects*@
        <MudContainer Class="d-flex align-center mt-4">
            <MudAvatar Class="mud-elevation-25">
                <MudIcon Icon="@Icons.Filled.Apps"/>
            </MudAvatar>

            <MudText Class="ml-2" Typo="Typo.h5">Projects</MudText>
        </MudContainer>

        <MudText Class="mt-2" Typo="Typo.body1">
            I have created a number of various applications which help people around the world. These apps vary from Windows apps, website extensions to websites.
            If you would like to browse through my projects, take a look <MudLink Href="/projects"><b>here</b></MudLink>.
        </MudText>

        @*Contact me*@
        <MudContainer Class="d-flex align-center mt-4">
            <MudAvatar Class="mud-elevation-25">
                <MudIcon Icon="@Icons.Filled.Message"/>
            </MudAvatar>

            <MudText Class="ml-2" Typo="Typo.h5">Contact me</MudText>
        </MudContainer>

        <MudText Class="mt-2" Typo="Typo.body1" GutterBottom="true">
            Please see below services wherein I can be found:
        </MudText>

        <MudButtonGroup Class="d-flex justify-center" Color="Color.Primary" Variant="Variant.Outlined">
            <MudLink Href="https://github.com/Coke21" Target="_blank" Underline="Underline.None">
                <MudButton StartIcon="@Icons.Custom.Brands.GitHub" IconColor="Color.Primary">
                    GitHub
                </MudButton>
            </MudLink>

            <MudLink Href="https://www.linkedin.com/in/artur21" Target="_blank" Underline="Underline.None">
                <MudButton StartIcon="@Icons.Custom.Brands.LinkedIn" IconColor="Color.Primary">
                    LinkedIn
                </MudButton>
            </MudLink>
        </MudButtonGroup>
    </MudPaper>
</MudContainer>
