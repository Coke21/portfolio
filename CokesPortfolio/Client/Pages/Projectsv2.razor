        <MudChip Icon="@Icons.Material.Filled.DesktopWindows" Value="@("Desktop")" />
        <MudChip Icon="@Icons.Material.Filled.Extension" Value="@("Extensions")" />
        <MudChip Icon="@Icons.Material.Filled.SmartToy" Value="@("Tools & Bots")" /> *@
    </MudChipSet>

    <MudText Typo="Typo.h5" Style="font-weight: bold" Class="mb-4 mt-5">⭐ Featured Projects</MudText>

    <MudGrid>
@*         <MudItem xs="12" sm="6">
            <MudCard>
                <MudCardMedia Style="background-size: contain; background-position: center;" Image="icons/gavel.png" Height="100" />
                <MudCardContent>
