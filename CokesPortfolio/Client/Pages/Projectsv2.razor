@page "/projectsv2"
<PageTitle>Projects v2 | Artur's Portfolio</PageTitle>

<MudContainer Class="mt-8" MaxWidth="MaxWidth.Large">
    <MudChipSet T="Category" 
                SelectedValues="_selectedCategories" 
                SelectedValuesChanged="OnSelectedChangedCategories"
                SelectionMode="SelectionMode.MultiSelection" 
                CheckMark="true" 
                Variant="Variant.Text"
                Color="Color.Default">
        @foreach (var item in Categories.AllCategories)
        {
            <MudChip Icon="@item.Icon" Value="@item">
                @item.Name
            </MudChip>
        }
    </MudChipSet>

    @if (FilteredProjects.Any(i => i.IsFeatured))
    {
        <MudText Typo="Typo.h5" Style="font-weight: bold" Class="mb-4 mt-5">⭐ Featured Projects</MudText>
    }

    <MudGrid>
        @foreach (var item in FilteredProjects)
        {
            <MudItem xs="12" sm="6">
                <MudCard>
                    <MudCardMedia Style="background-size: contain; background-position: center;" Image="icons/gavel.png" Height="100" />
                    <MudCardContent>
                        <MudText Typo="Typo.h5">@item.Description</MudText>
                        <MudText Typo="Typo.body2">Old paint found on a stone house door.</MudText>
                        <MudText Typo="Typo.body2">This photo was taken in a small village in Istra Croatia.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary">Share</MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Primary">Learn more</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</MudContainer>


@code {
    private IReadOnlyCollection<Category> _selectedCategories = new List<Category>() { Categories.All };

    private IEnumerable<IProject> FilteredProjects =>
        _selectedCategories.Contains(Categories.All)
            ? ProjectItem.AllProjects()
            : ProjectItem.AllProjects()
                .Where(p => p.Categories.Any(c => _selectedCategories.Contains(c)));

    private void OnSelectedChangedCategories(IReadOnlyCollection<Category> values)
    {
        List<Category> selected = values.ToList();

        if (selected.Contains(Categories.All) && selected.Count > 1)
            selected = new() { Categories.All };

        if (!selected.Any())
            selected = new() { Categories.All };

        _selectedCategories = selected;
    }
}
