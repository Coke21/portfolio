@page "/projectsv2"
@using CokesPortfolio.Client.Utilities.ProjectCategories
@using CokesPortfolio.Client.Utilities.ProjectItems


<PageTitle>Projects v2 | Artur's Portfolio</PageTitle>

@inject ProjectItem ProjectItem;
@inject ProjectCategory ProjectCategory;

<MudContainer Class="mt-8" MaxWidth="MaxWidth.Large">
    <MudChipSet @bind-SelectedValues="_selected" SelectionMode="SelectionMode.MultiSelection" CheckMark="_checkMark" Variant="Variant.Text" Color="Color.Default">
        @foreach (var item in ProjectCategory.GetProjectCategoryModels())
        {
            <MudChip Icon="@item.Icon" Value="@(item.EnumName)"/>
        }
@*         <MudChip Icon="@Icons.Material.Filled.Apps" Value="@("All")" />
