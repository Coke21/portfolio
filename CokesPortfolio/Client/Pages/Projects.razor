@page "/projects"
<PageTitle>Projects | Artur's Portfolio</PageTitle>

<MudContainer Class="mt-8" MaxWidth="MaxWidth.False">
    <MudChipSet T="Category" 
                SelectedValues="SelectedCategories"
                SelectedValuesChanged="OnSelectedChangedCategories"
                SelectionMode="SelectionMode.MultiSelection" 
                CheckMark="true">
        @foreach (Category category in CategoryService.Categories)
        {
            <MudChip Icon="@category.Icon" Value="@category" Variant="Variant.Outlined" Color="Color.Default">
                @category.DisplayName
            </MudChip>
        }
    </MudChipSet>

    @foreach (IGrouping<Category, Project> groupProjects in ProjectViewModel.FilteredProjectsGrouped)
    {
        <MudText Typo="@groupProjects.Key.Typo" Class="@groupProjects.Key.Class" Style="@groupProjects.Key.Style">
            <MudIcon Icon="@groupProjects.Key.HeaderIcon" Color="@groupProjects.Key.IconColor" Class="mr-2"/> 
                @groupProjects.Key.HeaderName
        </MudText>

        <MudGrid Spacing="6">
            @foreach (Project project in groupProjects)
            {
                @* Set MudItem d-flex so the children will stretch to the same height as the tallest item in the row *@
                <MudItem xs="12" sm="6" md="4" lg="3" xl="2" Class="@($"mt-4 d-flex {groupProjects.Key.ChildClass}")">
                    <MudCard Class="project-card">

                        <MudCardMedia Image="@project.Card.CardMedia.Image" Class="ma-2" Style="@project.Card.CardMedia.Style" />

                        <MudCardContent>

                            <MudText Typo="Typo.h6" GutterBottom="true">
                                @project.Card.Title
                            </MudText>

                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
                                @foreach (var chip in project.Card.CardChip)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@chip.Text</MudChip>
                                }
                            </MudStack>

                            <MudText Typo="Typo.body2" Class="mb-4" Style="white-space: pre-line;">
                                @project.Card.Description
                            </MudText>

                        </MudCardContent>

                        <MudCardActions Class="px-4 pb-4">

                            @if (project.Card.IsLiveAppAvailable)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Launch"
                                           Href="@project.Card.LiveAppHref"
                                           Target="_blank">
                                    Live Demo
                                </MudButton>
                            }

                            <MudSpacer />

                            @if (project.Card.IsSourceCodeAvailable)
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Default"
                                           StartIcon="@Icons.Material.Filled.Code"
                                           Href="@project.Card.SourceCodeHref"
                                           Target="_blank">
                                    Source Code
                                </MudButton>
                            }

                            @if (project.Card.DetailsAvailable)
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Default">
                                    Details
                                </MudButton>
                            }
                        </MudCardActions>

                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>


    @code {
    private IReadOnlyCollection<Category> SelectedCategories
    {
        get => CategoryService.Categories
            .Where(c => ProjectViewModel.SelectedCategoryIds.Contains(c.Id))
            .ToList();
    }

    private void OnSelectedChangedCategories(IReadOnlyCollection<Category> values)
    {
        List<int> ids = values.Select(x => x.Id).ToList();

        if (ids.Contains(1) || ids.Count == 0)
            ids = new List<int> { CategoryService.Categories.First(c => c.SelectedByDefault).Id };

        ProjectViewModel.SelectedCategoryIds = ids;
    }
}
