@inherits LayoutComponentBase

<MudThemeProvider Theme="ThemeManager.MudTheme" @bind-IsDarkMode="@ThemeManager.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <MudAppBar Style="@GetAppBarStyle()" Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />

        <MudSpacer />

        <MudTooltip Text="Toggle theme">
            <MudIconButton Icon="@Icons.Material.Filled.Brightness4" Color="Color.Inherit" OnClick="@(() => SwitchMode())"/>
        </MudTooltip>
        <MudDivider Class="mx-4 my-3" FlexItem="true" Vertical="true"/>

        <MudTooltip Text="View my GitHub">
            <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Inherit" Href="https://github.com/Coke21" Target="_blank" />
        </MudTooltip>

        <MudTooltip Text="View my LinkedIn">
            <MudIconButton Icon="@Icons.Custom.Brands.LinkedIn" Color="Color.Inherit" Href="https://www.linkedin.com/in/artur21" Target="_blank" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1">
        <MudDrawerHeader Class="d-flex justify-center align-center pa-1">
            <MudLink Class="d-flex align-center" Style="font-weight: bold" Href="/" Typo="Typo.h6">
                 Artur's Portfolio
            </MudLink>
        </MudDrawerHeader>

        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False">
            @Body
        </MudContainer>
    </MudMainContent>

    <MudScrollToTop>
        <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.KeyboardArrowUp"/>
    </MudScrollToTop>
</MudLayout>

@code {
    protected override async Task OnInitializedAsync()
    {
        ThemeManager.IsDarkMode = await LocalStorage.GetItemAsync<bool>("isDarkMode");
    }

    bool _drawerOpen = true;
    void DrawerToggle() => _drawerOpen = !_drawerOpen;

    async Task SwitchMode()
    {
        ThemeManager.IsDarkMode = !ThemeManager.IsDarkMode;

        await LocalStorage.SetItemAsync<bool>("isDarkMode", ThemeManager.IsDarkMode);
    }

    private string GetAppBarStyle()
    {
        if (ThemeManager.IsDarkMode)
        {
            return "background: #27272f; color: white;";
        }

        return "background: linear-gradient(90deg, #2b2d42 0%, #434863 100%); color: white;";
    }
}
