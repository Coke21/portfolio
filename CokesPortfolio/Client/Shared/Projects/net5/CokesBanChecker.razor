        Summary:
    </MudText>

    <MudList>
        <MudListItem>
            <strong>Web Framework</strong>: Blazor (ASP.NET Core Hosted)
        </MudListItem>

        <MudListItem>
            <strong>UI Framework</strong>: MudBlazor
        </MudListItem>

        <MudListItem>
